{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truzhen.dev/contracts/deliberation-provider-lane-readmodel.schema.json",
  "title": "DeliberationProviderLaneReadModel",
  "description": "单一供应商适配通道的只读投影；不包含浏览器 DOM、凭据或供应商回答原文。",
  "type": "object",
  "additionalProperties": false,
  "required": ["lane_ref", "session_ref", "turn_ref", "provider_group", "provider_resource_ref", "provider_adapter_ref", "adapter_version", "adapter_digest", "access_mode", "release_eligibility", "runtime_readiness", "status", "created_at", "updated_at", "candidate_only", "non_formal"],
  "properties": {
    "lane_ref": {"type": "string", "minLength": 1},
    "session_ref": {"type": "string", "minLength": 1},
    "turn_ref": {"type": "string", "minLength": 1},
    "provider_group": {"type": "string", "enum": ["china_core", "china_extended", "international_supplement", "custom"]},
    "provider_resource_ref": {"type": "string", "minLength": 1},
    "provider_adapter_ref": {"type": "string", "minLength": 1},
    "adapter_version": {"type": "string", "minLength": 1},
    "adapter_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "access_mode": {"type": "string", "enum": ["official_api", "provider_authorized_web", "manual_web"]},
    "release_eligibility": {"type": "string", "enum": ["ready", "not_ready", "blocked", "stale"]},
    "runtime_readiness": {"type": "string", "enum": ["ready", "not_ready", "blocked", "provider_missing"]},
    "status": {"type": "string", "enum": ["selected", "preflight", "filling", "submitting", "awaiting_response", "capturing", "imported", "failed", "blocked", "captcha_required", "login_required", "adapter_drift", "timed_out", "excluded", "recovery_required", "cancelled"]},
    "browser_run_ref": {"type": "string", "minLength": 1},
    "tab_binding_ref": {"type": "string", "minLength": 1},
    "grant_ref": {"type": "string", "minLength": 1},
    "response_artifact_ref": {"type": "string", "minLength": 1},
    "response_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "response_byte_count": {"type": "integer", "minimum": 0},
    "provider_message_ref_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "capture_mode": {"type": "string", "enum": ["network_dom_match", "dom_fallback", "conflict_review_required"]},
    "failure_code": {"type": "string", "enum": ["login_required", "captcha_required", "adapter_drift", "timed_out", "capture_conflict", "recovery_required", "policy_stale", "digest_mismatch", "receipt_append_failed", "model_not_ready", "emergency_stop", "origin_mismatch"]},
    "failure_summary_redacted": {"type": "string", "maxLength": 280},
    "receipt_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "readOnly": true},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "candidate_only": {"type": "boolean", "const": true},
    "non_formal": {"type": "boolean", "const": true}
  }
}
