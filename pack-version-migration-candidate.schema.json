{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truzhen.local/contracts/pack-version-migration-candidate.schema.json",
  "title": "PackVersionMigrationCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "transaction_ref",
    "pack_ref",
    "from_pack_version_ref",
    "to_pack_version_ref",
    "risk_color",
    "required_owner_action",
    "status",
    "candidate_only",
    "non_formal",
    "created_at"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "transaction_ref": { "type": "string", "minLength": 1 },
    "pack_ref": { "type": "string", "minLength": 1 },
    "from_pack_version_ref": { "type": "string", "minLength": 1 },
    "to_pack_version_ref": { "type": "string", "minLength": 1 },
    "diff_summary": { "type": "string" },
    "risk_color": { "type": "string", "enum": ["green", "yellow", "orange", "red"] },
    "required_owner_action": { "type": "string", "enum": ["owner_confirm", "blocked"] },
    "status": { "type": "string", "enum": ["proposed", "owner_rejected", "owner_approved_pending_migration"] },
    "candidate_only": { "type": "boolean", "const": true },
    "non_formal": { "type": "boolean", "const": true },
    "created_at": { "type": "string", "minLength": 1 }
  }
}
