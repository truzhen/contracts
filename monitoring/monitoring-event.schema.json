{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truzhen.local/contracts/monitoring/monitoring-event.schema.json",
  "title": "MonitoringEvent",
  "description": "统一监控与诊断事件：哈希链可回放、脱敏后持久化；error_code 为打包后定位问题的稳定线索。",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "run_id", "sequence", "source_kind", "severity", "status", "created_at"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 0 },
    "previous_hash": { "type": "string" },
    "event_hash": { "type": "string" },
    "source_kind": { "type": "string", "minLength": 1 },
    "source_ref": { "type": "string" },
    "component_ref": { "type": "string" },
    "gateway_ref": { "type": "string" },
    "provider_ref": { "type": "string" },
    "transaction_ref": { "type": "string" },
    "candidate_ref": { "type": "string" },
    "decision_ref": { "type": "string" },
    "severity": { "enum": ["debug", "info", "warning", "error", "security"] },
    "status": { "type": "string", "minLength": 1 },
    "error_code": { "type": "string", "pattern": "^TZ-[A-Z]{2,8}-[A-Z0-9]{2,10}-\\d{3}$" },
    "message": { "type": "string" },
    "redacted_payload_json": { "type": "string" },
    "payload_hash": { "type": "string" },
    "secure_payload_ref": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "receipt_candidate_ref": { "type": "string" },
    "receipt_ref": { "type": "string" },
    "created_at": { "type": "string" }
  }
}
