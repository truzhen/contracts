{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truzhen.local/contracts/pack-manifest.schema.json",
  "title": "PackManifest",
  "description": "云端上传和 Pack 分发可校验的 canonical manifest。只声明包和依赖形状，不保存用户本机解析结果。",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack_id", "name", "version", "kind", "min_truzhen_version"],
  "properties": {
    "pack_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["scene_pack", "role_pack", "capability_pack", "skill_bundle"]
    },
    "min_truzhen_version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "region_code": { "type": "string" },
    "arch_tags": { "type": "array", "items": { "type": "string" } },
    "software_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/software_requirement" }
    },
    "provider_requirements": {
      "type": "array",
      "items": { "$ref": "provider-requirement.schema.json" }
    },
    "external_software_refs": {
      "type": "array",
      "deprecated": true,
      "description": "Deprecated: use software_requirements with version_range and resolver policy.",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "software_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "software_family",
        "version_range",
        "isolation_policy",
        "fallback_policy",
        "gateway_class",
        "risk_class"
      ],
      "properties": {
        "requirement_id": { "type": "string", "minLength": 1 },
        "software_family": { "type": "string", "minLength": 1 },
        "provider_family": { "type": "string" },
        "version_range": { "type": "string", "minLength": 1 },
        "adapter_range": { "type": "string" },
        "required_capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "license_policy": { "type": "string", "enum": ["any_osi", "copyleft_excluded", "review_required"] },
        "isolation_policy": {
          "type": "string",
          "enum": ["reuse_preferred", "isolated_install", "coexist_multi_version", "blocked"]
        },
        "fallback_policy": {
          "type": "string",
          "enum": ["blocked", "provider_missing", "manual_handoff", "not_ready"]
        },
        "optional": { "type": "boolean" },
        "gateway_class": { "type": "string", "enum": ["execution", "communication", "model", "memory"] },
        "risk_class": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
      }
    }
  }
}
